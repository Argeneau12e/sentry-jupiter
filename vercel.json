{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/price/(.*)", "dest": "/api/price.js" },
    { "src": "/tokens/(.*)", "dest": "/api/tokens.js" },
    { "src": "/prediction/(.*)", "dest": "/api/prediction.js" },
    { "src": "/swap/(.*)", "dest": "/api/swap.js" },
    { "src": "/trigger/(.*)", "dest": "/api/trigger.js" },
    { "src": "/recurring/(.*)", "dest": "/api/recurring.js" },
    { "src": "/rpc", "dest": "/api/rpc.js" },
    { "src": "/lend/(.*)", "dest": "/api/lend.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}